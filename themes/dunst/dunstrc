[global]
    monitor = 0
    follow = mouse

    width = 360
    height = (0, 120)
    origin = top-right
    offset = (12, 44)

    notification_limit = 5

    progress_bar = true
    progress_bar_height = 8
    progress_bar_frame_width = 1

    indicate_hidden = yes
    transparency = 8
    separator_height = 2
    padding = 12
    horizontal_padding = 12
    text_icon_padding = 8

    frame_width = 2
    frame_color = "#89b4fa"
    separator_color = frame

    sort = yes
    idle_threshold = 120

    font = JetBrains Mono 10
    line_height = 0

    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    ellipsize = middle

    icon_position = left
    min_icon_size = 32
    max_icon_size = 48

    sticky_history = yes
    history_length = 20

    corner_radius = 12

    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[urgency_low]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    timeout = 4

[urgency_normal]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    timeout = 6

[urgency_critical]
    background = "#1e1e2e"
    foreground = "#f38ba8"
    frame_color = "#f38ba8"
    timeout = 0
